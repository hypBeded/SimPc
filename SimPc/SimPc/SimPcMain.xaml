<Window x:Class="SimPc.SimPcMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimPc"
        mc:Ignorable="d"
        Title="SimPC"  Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        FontFamily="Segoe UI"
        TextElement.Foreground="#F0F0F0">

     <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <StackPanel>
                <TextBlock Text="КАТЕГОРИИ" Margin="20,20,20,10" FontSize="16" FontWeight="SemiBold" Foreground="#AAAAAA"/>
                <ListBox x:Name="CategoryListBox" Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource MenuItemStyle}">
                    <ListBox.Items>
                        <ListBoxItem>Процессоры</ListBoxItem>
                        <ListBoxItem>Видеокарты</ListBoxItem>
                        <ListBoxItem>Материнские платы</ListBoxItem>
                        <ListBoxItem>Оперативная память</ListBoxItem>
                        <ListBoxItem>Накопители</ListBoxItem>
                        <ListBoxItem>Блоки питания</ListBoxItem>
                        <ListBoxItem>Корпуса</ListBoxItem>
                    </ListBox.Items>
                </ListBox>

                <TextBlock Text="ФИЛЬТРЫ" Margin="20,30,20,10" FontSize="16" FontWeight="SemiBold" Foreground="#AAAAAA"/>

                <StackPanel Margin="20,0">
                    <TextBlock Text="Цена, руб." Margin="0,0,0,5" Foreground="#CCCCCC"/>
                    <Slider x:Name="PriceSlider" Style="{StaticResource SliderStyle}" Value="50000"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <TextBlock Text="0" Foreground="#CCCCCC"/>
                        <TextBlock Text=" - " Foreground="#CCCCCC"/>
                        <TextBlock Text="{Binding ElementName=PriceSlider, Path=Value, StringFormat={}{0:0} ₽}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
                
                <TextBlock Text="Производители" Margin="20,20,20,5" Foreground="#CCCCCC"/>
                <StackPanel Margin="20,0">
                    <CheckBox Content="Intel" Margin="0,3" Foreground="#F0F0F0"/>
                    <CheckBox Content="AMD" Margin="0,3" Foreground="#F0F0F0"/>
                    <CheckBox Content="NVIDIA" Margin="0,3" Foreground="#F0F0F0"/>
                    <CheckBox Content="Kingston" Margin="0,3" Foreground="#F0F0F0"/>
                    <CheckBox Content="Samsung" Margin="0,3" Foreground="#F0F0F0"/>
                </StackPanel>

                <Button Content="Применить фильтры" 
                        Margin="20,30,20,20" 
                        Padding="10,8"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <ItemsControl x:Name="ProductsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ProductCardStyle}" Width="240" Height="300">
                            <StackPanel>
                                <Border Background="#3E3E42" Height="120" CornerRadius="4" Margin="0,0,0,10">
                                    <TextBlock Text="🖥️" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#AAAAAA"/>
                                </Border>

                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5"/>
                                <TextBlock Text="{Binding Description}" Foreground="#AAAAAA" FontSize="12" TextWrapping="Wrap" Margin="0,2"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}" 
                                               Foreground="{StaticResource AccentBrush}" 
                                               FontSize="18" 
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="AddToBuildButton" 
                                            Content="{Binding IsInBuild}"
                                            Margin="10,0,0,0"
                                            Padding="8,5"
                                            Background="{StaticResource AccentBrush}"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Tag="{Binding}">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Column="2" Background="{StaticResource BuildPanelBackgroundBrush}" Padding="15">
            <StackPanel>
                <TextBlock Text="ТЕКУЩАЯ СБОРКА" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#AAAAAA"/>
                
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500">
                    <ItemsControl x:Name="BuildItemsControl" ItemsSource="{Binding BuildItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource BuildItemStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="{Binding Category}" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" Orientation="Vertical">
                                            <TextBlock Text="{Binding Product.Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Product.Price, StringFormat={}{0:N0} ₽}" Foreground="{StaticResource AccentBrush}" FontSize="14"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="2" Content="✖" 
                                                Width="24" Height="24"
                                                Background="Transparent"
                                                Foreground="#FF5555"
                                                BorderThickness="0"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Tag="{Binding}"
                                                ToolTip="Удалить из сборки"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Rectangle Height="1" Fill="#3D3D3D" Margin="0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Итого:" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TotalPriceTextBlock" Text="{Binding TotalPrice, StringFormat={}{0:N0} ₽}" 
                               Foreground="{StaticResource AccentBrush}" 
                               FontSize="24" 
                               FontWeight="Bold"/>
                </StackPanel>


                <WrapPanel Margin="0,20,0,0" HorizontalAlignment="Center">
                    <Button Content="Сохранить сборку" 
                            Margin="5" Padding="15,8"
                            Background="#2D2D2D"
                            Foreground="White"
                            BorderThickness="1"
                            BorderBrush="#3D3D3D"/>
                    <Button Content="Загрузить сборку" 
                            Margin="5" Padding="15,8"
                            Background="#2D2D2D"
                            Foreground="White"
                            BorderThickness="1"
                            BorderBrush="#3D3D3D"/>
                    <Button Content="Очистить" 
                            Margin="5" Padding="15,8"
                            Background="#2D2D2D"
                            Foreground="#FF5555"
                            BorderThickness="1"
                            BorderBrush="#FF5555"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
